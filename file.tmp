<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="MEGATAMA - Premium Corporate Construction & Engineering Company. Pengalaman lebih dari 10 tahun melayani proyek konstruksi, engineering, dan pengembangan properti dengan standar internasional.">
    <meta name="keywords" content="konstruksi, engineering, kontractor, perusahaan konstruksi, properti development">
    <meta name="author" content="MEGATAMA">
    <meta property="og:title" content="MEGATAMA - Construction & Engineering Company">
    <meta property="og:description" content="Premium Corporate Construction & Engineering Services">
    <meta property="og:image" content="src/assets/images/og-image.jpg">
    
    <title>MEGATAMA - Corporate Construction & Engineering</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    
    <!-- AOS CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <!-- Main CSS -->
    <link rel="stylesheet" href="src/css/style.css">
</head>
<body>
    <!-- Scroll Progress Bar -->
    <div class="scroll-progress"></div>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="navbar-container">
            <div class="navbar-logo">
                <img src="src/assets/images/logo.png" style="width: 35px;" alt="MEGATAMA Logo">
                <span>MEGATAMA</span>
            </div>
            
            <div class="navbar-menu">
                <a href="#hero">Beranda</a>
                <a href="#about">Tentang Kami</a>
                <a href="#services">Layanan</a>
                <a href="#projects">Proyek</a>
                <a href="#portfolio">Portofolio</a>
                <a href="#clients">Klien</a>
                <a href="#news">Berita</a>
                <a href="kontak.html">Kontak</a>
                <a href="login.html" class="text-corporate-bright font-bold"><i class="fas fa-lock mr-1"></i> Portal</a>
            </div>
            
            <button class="navbar-cta">Hubungi Kami</button>
            <div class="navbar-toggle">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section id="hero" class="hero">
        <!-- Background Video/Image Fallback -->
        <div class="hero-video-bg" style="background: url('src/assets/images/bg-hero.jpeg') center/cover no-repeat;"></div>
        <div class="hero-overlay"></div>
        
        <div class="hero-content">
            <div class="hero-badge">
                <i class="fas fa-star"></i> Berpengalaman Lebih Dari 10 Tahun
            </div>
            
            <h1 class="hero-title" data-aos="fade-up">
                Membangun Masa Depan Dengan Inovasi dan Kualitas
            </h1>
            
            <p class="hero-subtitle" data-aos="fade-up" data-aos-delay="100">
                Kami menyediakan layanan konstruksi, engineering, konsultasi, mekanikal, elektrikal, plumbing, dan pengembangan properti dengan standar profesional internasional.
            </p>
            
            <div class="hero-buttons" data-aos="fade-up" data-aos-delay="200">
                <button class="btn-primary">
                    <i class="fas fa-phone-alt mr-2"></i> Konsultasi Sekarang
                </button>
                <button class="btn-secondary">
                    <i class="fas fa-images mr-2"></i> Lihat Portofolio
                </button>
            </div>
            
            <!-- Counter Animation -->
            <div class="counter-grid" data-aos="zoom-in" data-aos-delay="300">
                <div class="counter-item">
                    <div class="counter-number" data-target="10">0</div>
                    <div class="counter-label">Tahun Pengalaman</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number" data-target="500">0</div>
                    <div class="counter-label">Proyek Selesai</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number" data-target="100">0</div>
                    <div class="counter-label">Klien Puas</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number" data-target="50">0</div>
                    <div class="counter-label">Tenaga Ahli</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ABOUT US SECTION -->
    <section id="about" class="section bg-corporate-light">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                <!-- Left: Images -->
                <div class="relative h-96 md:h-full" data-aos="fade-right">
                    <div class="absolute inset-0 bg-gradient-to-br from-corporate-bright to-corporate-dark rounded-2xl opacity-10"></div>
                    <img src="https://placehold.co/500x600/0B1F3A/FFFFFF?text=Perusahaan" alt="Company" class="w-full h-full object-cover rounded-2xl shadow-2xl relative z-10">
                    <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-corporate-bright rounded-xl shadow-lg opacity-20 -z-10"></div>
                </div>
                
                <!-- Right: Content -->
                <div data-aos="fade-left">
                    <h2 class="section-title text-left mb-6">Tentang MEGATAMA</h2>
                    
                    <p class="text-gray-700 mb-6 leading-relaxed">
                        MEGATAMA adalah perusahaan konstruksi dan engineering terkemuka dengan pengalaman lebih dari 10 tahun melayani berbagai sektor industri. Kami berkomitmen untuk memberikan solusi terbaik dengan standar kualitas internasional.
                    </p>
                    
                    <div class="mb-8">
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Visi Kami</h3>
                        <p class="text-gray-700">Menjadi perusahaan konstruksi dan engineering pilihan utama di Asia dengan standar kualitas dan inovasi terdepan.</p>
                    </div>
                    
                    <div class="mb-8">
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Misi Kami</h3>
                        <p class="text-gray-700">Memberikan layanan profesional, inovatif, dan tepat waktu untuk membangun infrastruktur berkualitas yang berkelanjutan.</p>
                    </div>
                    
                    <!-- Values Cards -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-4 bg-white rounded-lg border-l-4 border-corporate-bright shadow-md hover:shadow-lg transition-shadow" data-aos="fade-up">
                            <i class="fas fa-handshake text-corporate-bright text-2xl mb-2"></i>
                            <h4 class="font-semibold text-corporate-dark mb-1">Integritas</h4>
                            <p class="text-sm text-gray-600">Komitmen penuh pada kepercayaan</p>
                        </div>
                        <div class="p-4 bg-white rounded-lg border-l-4 border-corporate-bright shadow-md hover:shadow-lg transition-shadow" data-aos="fade-up" data-aos-delay="100">
                            <i class="fas fa-briefcase text-corporate-bright text-2xl mb-2"></i>
                            <h4 class="font-semibold text-corporate-dark mb-1">Profesionalisme</h4>
                            <p class="text-sm text-gray-600">Standar kerja tertinggi</p>
                        </div>
                        <div class="p-4 bg-white rounded-lg border-l-4 border-corporate-bright shadow-md hover:shadow-lg transition-shadow" data-aos="fade-up" data-aos-delay="200">
                            <i class="fas fa-lightbulb text-corporate-bright text-2xl mb-2"></i>
                            <h4 class="font-semibold text-corporate-dark mb-1">Inovasi</h4>
                            <p class="text-sm text-gray-600">Solusi kreatif dan modern</p>
                        </div>
                        <div class="p-4 bg-white rounded-lg border-l-4 border-corporate-bright shadow-md hover:shadow-lg transition-shadow" data-aos="fade-up" data-aos-delay="300">
                            <i class="fas fa-star text-corporate-bright text-2xl mb-2"></i>
                            <h4 class="font-semibold text-corporate-dark mb-1">Kualitas</h4>
                            <p class="text-sm text-gray-600">Hasil kerja terbaik</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- BUSINESS DIVISION SECTION -->
    <section id="divisions" class="section bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="section-title" data-aos="fade-up">Bidang Usaha Kami</h2>
            <p class="section-subtitle" data-aos="fade-up">Layanan komprehensif untuk semua kebutuhan konstruksi dan engineering</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Card 1 -->
                <div class="p-8 bg-gradient-to-br from-white to-corporate-light rounded-xl shadow-lg card-hover card-shine" data-aos="fade-up">
                    <div class="text-5xl text-corporate-bright mb-4">
                        <i class="fas fa-building"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-corporate-dark mb-3">Konstruksi Bangunan</h3>
                    <p class="text-gray-700">Pembangunan gedung bertingkat, perkantoran, dan fasilitas komersial dengan teknologi konstruksi modern.</p>
                </div>
                
                <!-- Card 2 -->
                <div class="p-8 bg-gradient-to-br from-white to-corporate-light rounded-xl shadow-lg card-hover card-shine" data-aos="fade-up" data-aos-delay="100">
                    <div class="text-5xl text-corporate-bright mb-4">
                        <i class="fas fa-cogs"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-corporate-dark mb-3">Mechanical Engineering</h3>
                    <p class="text-gray-700">Desain dan implementasi sistem mekanik untuk HVAC, pneumatik, dan sistem produksi.</p>
                </div>
                
                <!-- Card 3 -->
                <div class="p-8 bg-gradient-to-br from-white to-corporate-light rounded-xl shadow-lg card-hover card-shine" data-aos="fade-up" data-aos-delay="200">
                    <div class="text-5xl text-corporate-bright mb-4">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-corporate-dark mb-3">Electrical Engineering</h3>
                    <p class="text-gray-700">Instalasi sistem kelistrikan, panel kontrol, dan renewable energy solutions.</p>
                </div>
                
                <!-- Card 4 -->
                <div class="p-8 bg-gradient-to-br from-white to-corporate-light rounded-xl shadow-lg card-hover card-shine" data-aos="fade-up" data-aos-delay="300">
                    <div class="text-5xl text-corporate-bright mb-4">
                        <i class="fas fa-water"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-corporate-dark mb-3">Plumbing System</h3>
                    <p class="text-gray-700">Sistem pipa, sanitasi, dan water treatment dengan standar internasional.</p>
                </div>
                
                <!-- Card 5 -->
                <div class="p-8 bg-gradient-to-br from-white to-corporate-light rounded-xl shadow-lg card-hover card-shine" data-aos="fade-up" data-aos-delay="400">
                    <div class="text-5xl text-corporate-bright mb-4">
                        <i class="fas fa-drafting-compass"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-corporate-dark mb-3">Konsultan Perencanaan</h3>
                    <p class="text-gray-700">Konsultasi desain, perencanaan proyek, dan feasibility study mendalam.</p>
                </div>
                
                <!-- Card 6 -->
                <div class="p-8 bg-gradient-to-br from-white to-corporate-light rounded-xl shadow-lg card-hover card-shine" data-aos="fade-up" data-aos-delay="500">
                    <div class="text-5xl text-corporate-bright mb-4">
                        <i class="fas fa-home"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-corporate-dark mb-3">Property Development</h3>
                    <p class="text-gray-700">Pengembangan properti residensial dan komersial dengan lokasi strategis.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SERVICES SECTION -->
    <section id="services" class="section bg-corporate-gray">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="section-title" data-aos="fade-up">Layanan Unggulan Kami</h2>
            <p class="section-subtitle" data-aos="fade-up">Solusi terpadu untuk semua kebutuhan proyek konstruksi</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="group relative p-8 bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105" data-aos="fade-up">
                    <div class="absolute inset-0 bg-gradient-to-r from-corporate-bright to-corporate-dark opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <i class="fas fa-tasks text-4xl text-corporate-bright mb-4"></i>
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Perencanaan Proyek</h3>
                        <p class="text-gray-700">Perencanaan matang dengan metodologi terbukti untuk hasil maksimal.</p>
                        <div class="mt-4 inline-block w-1 h-1 bg-corporate-bright rounded-full group-hover:w-8 transition-all duration-300"></div>
                    </div>
                </div>

                <div class="group relative p-8 bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105" data-aos="fade-up" data-aos-delay="100">
                    <div class="absolute inset-0 bg-gradient-to-r from-corporate-bright to-corporate-dark opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <i class="fas fa-pencil-ruler text-4xl text-corporate-bright mb-4"></i>
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Design Engineering</h3>
                        <p class="text-gray-700">Desain detail dengan CAD profesional dan simulasi struktur.</p>
                        <div class="mt-4 inline-block w-1 h-1 bg-corporate-bright rounded-full group-hover:w-8 transition-all duration-300"></div>
                    </div>
                </div>

                <div class="group relative p-8 bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105" data-aos="fade-up" data-aos-delay="200">
                    <div class="absolute inset-0 bg-gradient-to-r from-corporate-bright to-corporate-dark opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <i class="fas fa-hammer text-4xl text-corporate-bright mb-4"></i>
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Pembangunan Gedung</h3>
                        <p class="text-gray-700">Eksekusi konstruksi dengan standar keselamatan tertinggi.</p>
                        <div class="mt-4 inline-block w-1 h-1 bg-corporate-bright rounded-full group-hover:w-8 transition-all duration-300"></div>
                    </div>
                </div>

                <div class="group relative p-8 bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105" data-aos="fade-up" data-aos-delay="300">
                    <div class="absolute inset-0 bg-gradient-to-r from-corporate-bright to-corporate-dark opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <i class="fas fa-tools text-4xl text-corporate-bright mb-4"></i>
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Renovasi Bangunan</h3>
                        <p class="text-gray-700">Perbaikan dan modernisasi bangunan dengan minimal disruption.</p>
                        <div class="mt-4 inline-block w-1 h-1 bg-corporate-bright rounded-full group-hover:w-8 transition-all duration-300"></div>
                    </div>
                </div>

                <div class="group relative p-8 bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105" data-aos="fade-up" data-aos-delay="400">
                    <div class="absolute inset-0 bg-gradient-to-r from-corporate-bright to-corporate-dark opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <i class="fas fa-clipboard-list text-4xl text-corporate-bright mb-4"></i>
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Manajemen Proyek</h3>
                        <p class="text-gray-700">Pengelolaan terintegrasi dari awal hingga penyelesaian proyek.</p>
                        <div class="mt-4 inline-block w-1 h-1 bg-corporate-bright rounded-full group-hover:w-8 transition-all duration-300"></div>
                    </div>
                </div>

                <div class="group relative p-8 bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105" data-aos="fade-up" data-aos-delay="500">
                    <div class="absolute inset-0 bg-gradient-to-r from-corporate-bright to-corporate-dark opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <i class="fas fa-check-circle text-4xl text-corporate-bright mb-4"></i>
                        <h3 class="text-xl font-bold text-corporate-dark mb-3">Pengawasan Konstruksi</h3>
                        <p class="text-gray-700">Quality control dan monitoring real-time selama konstruksi.</p>
                        <div class="mt-4 inline-block w-1 h-1 bg-corporate-bright rounded-full group-hover:w-8 transition-all duration-300"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PORTFOLIO SECTION -->
    <section id="portfolio" class="section bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="section-title" data-aos="fade-up">Portfolio Proyek</h2>
            <p class="section-subtitle" data-aos="fade-up">Koleksi proyek unggulan kami di berbagai sektor</p>
            
            <!-- Filter Buttons -->
            <div class="flex flex-wrap justify-center gap-3 mb-12" data-aos="fade-up">
                <button class="btn-tag active" data-filter="all">Semua</button>
                <button class="btn-tag" data-filter="gedung">Gedung</button>
                <button class="btn-tag" data-filter="infrastruktur">Infrastruktur</button>
                <button class="btn-tag" data-filter="industri">Industri</button>
                <button class="btn-tag" data-filter="properti">Properti</button>
            </div>
            
            <!-- Masonry Gallery -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="portfolioGrid">
                <!-- Portfolio Item 1 -->
                <div class="portfolio-item group relative overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 cursor-pointer" data-category="gedung" data-aos="zoom-in">
                    <img src="https://placehold.co/500x400/0B1F3A/FFFFFF?text=Gedung+Perkantoran" alt="Gedung Perkantoran" class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300">
