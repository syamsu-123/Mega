                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
                        <h3 class="text-xl font-bold text-white mb-2">Kompleks Residensial Modern</h3>
                        <p class="text-gray-200 text-sm">Bandung | 2023</p>
                    </div>
                </div>

                <!-- Portfolio Item 4 -->
                <div class="portfolio-item group relative overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 cursor-pointer" data-category="industri" data-aos="zoom-in" data-aos-delay="300">
                    <img src="https://placehold.co/500x400/1E88E5/FFFFFF?text=Pabrik+Modern" alt="Pabrik" class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
                        <h3 class="text-xl font-bold text-white mb-2">Pabrik Manufacturing</h3>
                        <p class="text-gray-200 text-sm">Karawang | 2023</p>
