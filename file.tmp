                        <p class="text-gray-200 text-sm">Bali | 2022</p>
                    </div>
                </div>

                <!-- Portfolio Item 7 -->
                <div class="portfolio-item group relative overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 cursor-pointer" data-category="infrastruktur" data-aos="zoom-in" data-aos-delay="600">
                    <img src="https://placehold.co/500x400/0B1F3A/FFFFFF?text=Terminal+Transportasi" alt="Terminal" class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300">
