                </div>

                <!-- Portfolio Item 5 -->
                <div class="portfolio-item group relative overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 cursor-pointer" data-category="gedung" data-aos="zoom-in" data-aos-delay="400">
                    <img src="https://placehold.co/500x400/0B1F3A/FFFFFF?text=Mall+Modern" alt="Mall" class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
